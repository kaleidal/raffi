[Desktop Entry]
Name=Raffi
Comment=Play videos, manage a library, and connect your own streaming sources.
Exec=raffi %U
Terminal=false
Type=Application
Icon=al.kaleid.raffi
StartupWMClass=al.kaleid.raffi
Categories=AudioVideo;Player;Video;
MimeType=video/mp4;video/x-matroska;video/webm;video/x-msvideo;video/quicktime;x-scheme-handler/raffi;
