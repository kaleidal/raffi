    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^25.9.1",
    "svelte": "^5.56.0",
    "svelte-check": "^4.4.8",
    "tailwindcss": "^4.3.0",
    "typescript": "~6.0.3",
    "vite": "^8.0.14",
    "wrangler": "^4.95.0"
  },
  "dependencies": {
    "@raffi/app": "workspace:*",
    "@ave-id/sdk": "^0.9.2",
    "@lucide/svelte": "^1.17.0",
    "eventemitter3": "^5.0.4",
    "hls.js": "^1.6.16",
    "posthog-js": "^1.376.4"
  }
