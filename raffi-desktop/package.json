{
  "name": "raffi",
  "private": true,
  "version": "0.7.0",
  "type": "module",
  "main": "electron/main.cjs",
  "description": "A modern video player",
  "author": {
    "name": "Kaleidal",
    "email": "hello@kaleid.al"
  },
  "homepage": "https://raffi.al",
  "scripts": {
    "dev": "vite",
    "electron:dev": "npm run server:build && cross-env NODE_ENV=development concurrently \"npm run dev\" \"wait-on http://localhost:5173 && cross-env ELECTRON_DISABLE_SANDBOX=1 electron .\"",
    "electron:dev:only": "cross-env ELECTRON_DISABLE_SANDBOX=1 electron .",
    "build": "vite build",
    "server:build": "node build_binary.cjs",
    "dist": "npm run server:build && npm run build && electron-builder",
    "check": "svelte-check --tsconfig ./tsconfig.json"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@tsconfig/svelte": "^5.0.8",
    "@types/node": "^25.6.0",
    "@typescript-eslint/types": "^8.58.1",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1",
    "ffmpeg-static": "^5.3.0",
    "ffprobe-static": "^3.1.0",
    "png-to-ico": "^3.0.1",
    "svelte": "^5.55.3",
    "svelte-check": "^4.4.6",
    "typescript": "~6.0.2",
    "vite": "^8.0.8",
    "wait-on": "^9.0.5"
  },
  "build": {
    "appId": "al.kaleid.raffi",
    "productName": "Raffi",
    "directories": {
      "buildResources": "build",
      "output": "release"
    },
    "publish": {
      "provider": "github",
      "owner": "kaleidal",
      "repo": "raffi"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "asar": true,
    "linux": {
      "target": [
        "deb",
        "AppImage",
        "rpm"
      ],
      "icon": "build/icons",
      "category": "Video",
      "extraResources": [
        {
          "from": "electron/decoder-x86_64-unknown-linux-gnu",
          "to": "decoder-x86_64-unknown-linux-gnu"
        },
        {
          "from": "electron/ffmpeg",
          "to": "ffmpeg"
        },
        {
          "from": "electron/ffprobe",
          "to": "ffprobe"
        }
      ]
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "universal"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "universal"
          ]
        }
      ],
      "icon": "build/icons/icon.icns",
      "category": "public.app-category.video",
      "identity": null,
      "extraResources": [
        {
          "from": "electron/decoder-aarch64-apple-darwin",
          "to": "decoder-aarch64-apple-darwin"
        },
        {
          "from": "electron/decoder-x86_64-apple-darwin",
          "to": "decoder-x86_64-apple-darwin"
        },
        {
          "from": "electron/ffmpeg-x64",
          "to": "ffmpeg-x64"
        },
        {
          "from": "electron/ffmpeg-arm64",
          "to": "ffmpeg-arm64"
        },
        {
          "from": "electron/ffprobe-x64",
          "to": "ffprobe-x64"
        },
        {
          "from": "electron/ffprobe-arm64",
          "to": "ffprobe-arm64"
        }
      ]
    },
    "win": {
      "target": [
        "nsis",
        "msi"
      ],
      "icon": "build/icons/icon.ico",
      "extraResources": [
        {
          "from": "electron/decoder-windows-amd64.exe",
          "to": "decoder-windows-amd64.exe"
        },
        {
          "from": "electron/ffmpeg.exe",
          "to": "ffmpeg.exe"
        },
        {
          "from": "electron/ffprobe.exe",
          "to": "ffprobe.exe"
        }
      ]
    },
    "fileAssociations": [
      {
        "ext": "mp4",
        "name": "Video File",
        "role": "Viewer"
      },
      {
        "ext": "mkv",
        "name": "Video File",
        "role": "Viewer"
      },
      {
        "ext": "avi",
        "name": "Video File",
        "role": "Viewer"
      },
      {
        "ext": "webm",
        "name": "Video File",
        "role": "Viewer"
      },
      {
        "ext": "mov",
        "name": "Video File",
        "role": "Viewer"
      }
    ],
    "asarUnpack": [
      "node_modules/**/*.node",
      "node_modules/**/prebuilds/**"
    ]
  },
  "dependencies": {
    "@ave-id/sdk": "^0.6.0",
    "@lucide/svelte": "^1.8.0",
    "@ryuziii/discord-rpc": "^1.0.1-rc.1",
    "@tailwindcss/vite": "^4.2.2",
    "convex": "^1.35.1",
    "electron-updater": "^6.8.3",
    "eventemitter3": "^5.0.4",
    "express": "^5.2.1",
    "hls.js": "^1.6.15",
    "posthog-js": "^1.367.0",
    "tailwindcss": "^4.2.2"
  },
  "trustedDependencies": [
    "core-js",
    "electron",
    "ffmpeg-static",
    "protobufjs"
  ]
}
